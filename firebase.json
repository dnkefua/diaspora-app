{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "package.json",
      "package-lock.json",
      "npm-debug.log",
      "yarn.lock",
      "pnpm-lock.yaml",
      "tsconfig.json",
      "README.md",
      "*.md",
      "*.yml",
      "*.yaml",
      "**/.*",
      ".git",
      ".git/**",
      ".github",
      ".github/**",
      ".claude",
      ".claude/**",
      ".expo",
      ".expo/**",
      ".firebase",
      "**/node_modules/**",
      "diaspora-mobile/**",
      "Media resources/TheDiaspora app logo.png",
      "seed-data.js",
      "FIREBASE_SETUP.md",
      "firebase-debug.log",
      "*.log"
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|svg|png|jpg|jpeg|webp)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=31536000"
          }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  }
}

{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      ".git",
      ".git/**",
      ".github",
      ".github/**",
      ".claude",
      ".claude/**",
      "**/node_modules/**",
      "Media resources/TheDiaspora app logo.png",
      "seed-data.js",
      "FIREBASE_SETUP.md",
      "firebase-debug.log",
      "*.log"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|svg|png|jpg|jpeg|webp)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=31536000"
          }
        ]
      }
    ]
  }
  ,
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
